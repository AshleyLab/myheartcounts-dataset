#!/bin/bash
# Generic from-raw downstream eval (PBS / GPU) — for encoder methods that need a GPU.
#
# Same public-API path as run_eval.pbs, but on a GPU node (:ngpus=1) for methods
# whose from-raw extraction runs a neural encoder — e.g. mae (MAE/LSM2 dense encoder
# over daily_hf), toto, chronos2, wbm.
#
# Usage (submit from the repo root):
#   qsub -v METHOD=mae,MHC_DATA_DIR=$HOME/yuze_mhc_ws/data jobs/imperial/pbs/run_eval_gpu.pbs
#
# NOTE (mae): the default checkpoint is the public HF ref hf://MyHeartCounts/openmhc-lsm2-daily,
# fetched on a cache miss (needs internet on the node; HF_HUB_DISABLE_XET=1 is set below for the
# RDS filesystem). To run fully offline, pass a LOCAL .ckpt via MAE_CHECKPOINT instead:
#   qsub -v METHOD=mae,MHC_DATA_DIR=$HOME/yuze_mhc_ws/data,MAE_CHECKPOINT=$HOME/yuze_mhc_ws/models/mae_lsm2.ckpt \
#        jobs/imperial/pbs/run_eval_gpu.pbs
# (Avoid '=' in the .ckpt filename — qsub -v parses VAR=VALUE on '='.)
#PBS -N run_eval_gpu
#PBS -l select=1:ncpus=8:mem=64gb:ngpus=1
#PBS -l walltime=24:00:00
#PBS -j oe
#PBS -o logs/

set -eo pipefail

cd "${PBS_O_WORKDIR:-.}"
mkdir -p logs
echo "=== downstream eval (PBS/GPU): METHOD=${METHOD:-mae} ==="
echo "Node: $(hostname) | Job: ${PBS_JOBID:-local} | PWD: $(pwd) | Date: $(date)"
nvidia-smi --query-gpu=name,memory.total --format=csv,noheader || true

source "$HOME/miniforge3/bin/activate" py310
python -V

export PYTHONNOUSERSITE=1
export PYTHONPATH="$PWD/src:${PYTHONPATH:-}"
export TMPDIR="${EPHEMERAL:-/tmp}/pbs_${PBS_JOBID:-$$}"
# Per-job bytecode cache: avoids stale .pyc on the shared filesystem, whose coarse
# mtimes can defeat Python's source-vs-bytecode check after a code edit.
export PYTHONPYCACHEPREFIX="$TMPDIR/pycache"
export HF_HOME="${HF_HOME:-$TMPDIR/hf_cache}"
# hf-xet's temp/lock file ops fail on the RDS network filesystem; force plain HTTPS.
export HF_HUB_DISABLE_XET=1
mkdir -p "$HF_HOME"

# Do NOT set LABEL_*_PATH to src/labels/* (stale 33-task subset); use data/labels defaults.
export METHOD="${METHOD:-mae}"
: "${MHC_DATA_DIR:?set MHC_DATA_DIR to the dataset root (e.g. \$HOME/yuze_mhc_ws/data)}"
export OUT_CSV="${OUT_CSV:-eval_${METHOD}.csv}"
echo "MAE_CHECKPOINT=${MAE_CHECKPOINT:-(default: hf://MyHeartCounts/openmhc-lsm2-daily)}"

python scripts/run_eval.py

echo "=== downstream eval complete ($METHOD) -> $OUT_CSV ==="
date
